# Bedmock provider configuration example.
# Copy these variables into your application's .env file, or export them in
# the same shell before running your application.

# Source Bedrock-shaped model ID used by your application. Bedmock uses this
# to select a source codec; it does not call AWS Bedrock.
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=us.amazon.nova-2-lite-v1:0

# Gemini through Google AI Studio / OpenAI-compatible endpoint.
BEDROCK_BRIDGE_PROVIDER=gemini
BEDROCK_BRIDGE_MODEL=<current-gemini-model>
GEMINI_API_KEY=<secret>

# OpenAI alternative.
# BEDROCK_BRIDGE_PROVIDER=openai
# BEDROCK_BRIDGE_MODEL=<current-openai-model>
# OPENAI_API_KEY=<secret>

# OpenRouter alternative.
# BEDROCK_BRIDGE_PROVIDER=openrouter
# BEDROCK_BRIDGE_MODEL=<provider/model-slug>
# OPENROUTER_API_KEY=<secret>

# Groq alternative.
# BEDROCK_BRIDGE_PROVIDER=groq
# BEDROCK_BRIDGE_MODEL=<current-groq-model>
# GROQ_API_KEY=<secret>
