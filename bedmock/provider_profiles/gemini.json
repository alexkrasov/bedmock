{
  "id": "gemini",
  "transport": "openai_chat_completions",
  "base_url": "https://generativelanguage.googleapis.com/v1beta/openai",
  "endpoint_path": "/chat/completions",
  "api_key_env": ["GEMINI_API_KEY", "GOOGLE_API_KEY"],
  "default_headers": {},
  "capabilities": {
    "chat_completions": true,
    "streaming": true,
    "tools": "model_dependent",
    "strict_tool_schema": "model_dependent",
    "vision": "model_dependent",
    "structured_output": "model_dependent",
    "reasoning": "model_dependent",
    "token_counting": "model_dependent"
  },
  "parameter_policy": {
    "omit_null_values": true,
    "unsupported": []
  },
  "output_token_parameter": {
    "default": "max_tokens"
  },
  "token_counting": {
    "strategy": "gemini_count_tokens",
    "base_url": "https://generativelanguage.googleapis.com/v1beta"
  }
}
